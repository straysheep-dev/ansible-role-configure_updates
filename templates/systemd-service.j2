[Unit]
Description=Run {{ item.name }} to handle unattended updates
Documentation=https://github.com/straysheep-dev/ansible-role-configure_updates
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User={{ item.user }}
ExecStart=/bin/bash /usr/local/bin/{{ item.script }}
TimeoutStartSec={{ item.timeout }}
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal
